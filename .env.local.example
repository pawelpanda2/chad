# Local Mac — shared values for BOTH local dev modes:
#   - bash-scripts/dashboard/02_local_mac/      (pnpm/tmuxinator, no Docker)
#   - bash-scripts/dashboard/03_local_mac_docker/ (docker-compose)
#
# The two modes are similar enough that keeping one shared secrets/paths
# file is simpler than two near-duplicate .env files. Ports, Docker-network
# DNS names, and COMPOSE_PROJECT_NAME differ between the two modes and are
# hardcoded directly in each mode's own scripts
# (bash-scripts/dashboard/02_local_mac/*.sh vs
# bash-scripts/dashboard/03_local_mac_docker/*.sh) — not in this file, and
# not in any separate config file.
#
# Copy to .env.local and fill in real values. Never commit .env.local
# (only this .example is meant to be committed).

# ============================================
# MongoDB (local_mac_docker only — local_mac's non-Docker mode doesn't run
# Mongo at all yet)
# ============================================
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me

# Full connection string for CP items — same physical mongo container as
# BEEPER_MONGODB_URI below, different database (`chad`).
MONGODB_URI="mongodb://change_me:change_me@mongodb:27017/chad?authSource=admin"

# Beeper CRM's Mongo *server* URI — same physical mongo container as
# MONGODB_URI. Story 73: each CHAD user gets their own database
# (`beeper_<repoGuid>`, e.g. `beeper_21d11bdc-f1f4-44d1-b61a-3fa6b039c641`
# for pawel_f), computed by packages/dba/src/mongo.ts's getBeeperMongoDb()
# — this URI must NOT include a database segment (any segment present is
# ignored; the driver always calls client.db(`beeper_<repoGuid>`)
# explicitly). Predates this monorepo — collections
# (contacts/channels/messages/timeline_events/...) were ported from the
# standalone `contacts` repo, but the old single shared `beeper` database
# is retired as of Story 73 (see documentation/beeper/architecture.md).
BEEPER_MONGODB_URI="mongodb://change_me:change_me@mongodb:27017?authSource=admin"

# Which Mongo the local dashboard talks to — "local" (default, the
# chad-mongodb-local-mac-docker container above) or "qnap" (QNAP's
# chad-mongodb over Tailscale, 100.117.139.83:12040 — see
# bash-scripts/dashboard/03_local_mac_docker/01_config.sh, which overrides
# MONGODB_URI/BEEPER_MONGODB_URI itself in that mode).
DBA_MONGO_MODE=local

# ============================================
# Content Provider — host path holding real repo data. Must be the PARENT
# of a "repos/" folder, not repos/ itself (see documentation/content-provider/
# next-tasks/qnap-test-deployment.md §6).
#
# CP_REPOS_HOST_PATH_2 (Story 68, 2026-07-17): a second, independent repo
# search root — the owner's Mac has repos split across two separate Dropbox
# accounts/mounts ("main" + "kamilgame042"), each with its own repos/
# subfolder. Both are scanned; see GuidGroupsHelper.GetGuidGroupsForSearchFolders
# in packages/net-content-provider — it no longer appends "repos" and no
# longer only reads the first configured path.
# ============================================
CP_REPOS_HOST_PATH=./packages/dashboard/cp-root
CP_REPOS_HOST_PATH_2=./packages/dashboard/cp-root

# ============================================
# Database (Prisma) — SQLite, path relative to packages/dashboard for
# local_mac; local_mac_docker overrides this directly in its own scripts.
# ============================================
DATABASE_URL=file:./dev.db

# ============================================
# Console CLI — OpenAI key (get your own at platform.openai.com)
# ============================================
OPENAI_API_KEY=change_me

# ============================================
# App metadata
# ============================================
NEXT_PUBLIC_APP_NAME="Personal Dashboard"

# ============================================
# GHCR (GitHub Container Registry) — used by
# bash-scripts/dashboard/09_registry_test/02_build.sh to build the
# chad-dashboard image LOCALLY (never on QNAP — see Story 70) and push it to
# ghcr.io. The registry/owner/image name are non-secret and hardcoded in
# bash-scripts/dashboard/09_registry_test/01_config.sh (same pattern as
# ports elsewhere) — only real secrets live here.
#
# GHCR_PUSH_TOKEN: a GitHub Personal Access Token (classic) with ONLY the
# `write:packages` scope (that scope alone implies read — no need to also
# tick `read:packages`). Create at https://github.com/settings/tokens →
# "Generate new token (classic)" → tick `write:packages` only → generate →
# paste the value here (in .env.local, never in .env.local.example, never
# committed). GitHub Actions does NOT need this token at all — it uses the
# automatically-provided GITHUB_TOKEN instead (see
# .github/workflows/build-dashboard-image.yml).
# ============================================
GHCR_PUSH_USERNAME=change_me
GHCR_PUSH_TOKEN=change_me

# ============================================
# Story 72 — packages/dba data-providers config (Mongo/Content-Provider
# primary+follower layer, packages/dba/src/data-providers/config.ts).
# All optional — docker-compose.local.yml's defaults (Mongo primary, CP
# follower disabled) apply if these are left unset. See
# documentation/dba/data-providers-config.md.
# ============================================
DBA_MONGO_ENABLED=true
DBA_CONTENT_PROVIDER_ENABLED=false
DBA_PRIMARY_BACKEND=mongo
DBA_FOLLOWER_WRITES_ENABLED=false
DBA_SHADOW_READS_ENABLED=false

# ============================================
# Story 75 — Daily Tracker -> Google Sheets sync
# (packages/dba/src/google-sheets/config.ts). All optional — leaving
# GOOGLE_SHEETS_ENABLED unset/false disables the integration entirely (the
# default) and none of the other vars below are required in that case. See
# ai-docs/google-sheets/architecture.md for the full setup (Google Cloud
# project + Sheets API + service account + sharing the target spreadsheet(s)
# with the service account's email) and the sheet's column layout.
#
# GOOGLE_SHEETS_SPREADSHEET_MAP: one spreadsheet PER CHAD USER, never a
# single shared spreadsheet — every user owns their own Google account/
# spreadsheet. JSON object of {"username": "spreadsheetId"}. A user missing
# from this map gets their sync enqueue fail loudly (logged, never thrown
# into the caller) rather than silently landing in someone else's sheet.
# EVERY spreadsheet listed must be individually shared (Editor access) with
# the one service account email below.
#
# GOOGLE_SHEETS_DAILY_TRACKER_SHEET_NAME/GOOGLE_SHEETS_DATE_ENTRIES_SHEET_NAME
# have NO safe shared default on purpose: give each environment
# (local/TEST/PROD) its own tab names here, so a copy-pasted .env can't
# silently point two environments at the same tab. These tab names are
# shared across every user's own spreadsheet (each user's spreadsheet has
# its own "daily"/"dates" tabs, same names) — only the spreadsheet id
# varies per user, via the map above.
#
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY: paste the service account JSON key's
# "private_key" field value directly (with its literal \n sequences intact
# — they're un-escaped to real newlines automatically). Never commit the
# downloaded service-account JSON file itself anywhere in this repo.
# ============================================
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_MAP={"change_me_username":"change_me_spreadsheetId"}
GOOGLE_SHEETS_DAILY_TRACKER_SHEET_NAME=daily-tracker-local
GOOGLE_SHEETS_DATE_ENTRIES_SHEET_NAME=dates-local
GOOGLE_SERVICE_ACCOUNT_EMAIL=change_me@change_me.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=change_me
