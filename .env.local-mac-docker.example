# Local Mac dev — full stack under docker-compose (mongo + content-provider-api
# + dashboard), used by bash-scripts/dashboard/03_local_mac_docker/*.sh and
# docker-compose.local-mac-docker.yml.
#
# Copy to .env.local-mac-docker and fill in real values. Never commit
# .env.local-mac-docker (only this .example is meant to be committed).

# ============================================
# MongoDB
# ============================================
MONGODB_PORT=27017
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me
MONGODB_URI=mongodb://change_me:change_me@localhost:27017/chad?authSource=admin

# ============================================
# Content Provider API
# ============================================
# Host path holding real repo data. Must be the PARENT of a "repos/" folder,
# not the repos folder itself — see documentation/content-provider/next-tasks/
# qnap-test-deployment.md §6 (GuidGroupsHelper hardcodes appending "repos").
CP_REPOS_HOST_PATH=./packages/dashboard/cp-root
CONTENT_PROVIDER_API_PORT=12024

# ============================================
# Dashboard frontend
# ============================================
FRONTEND_PORT=12020
DATABASE_URL=file:/app/data/dev.db

# ============================================
# Console CLI — OpenAI key
# ============================================
OPENAI_API_KEY=change_me

# ============================================
# App metadata
# ============================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_NAME=Personal Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:12020
