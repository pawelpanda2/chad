# QNAP TEST — full dashboard stack (mongo + content-provider-api + dashboard)
# under docker-compose, used by bash-scripts/dashboard/04_qnap_test/*.sh,
# bash-scripts/dashboard/06_qnap_ssh/*_test.sh, and docker-compose.qnap-test.yml.
#
# NOTE: this is a DIFFERENT deployment from packages/net-content-provider/
# 03_scripts/qnap/*.sh, which deploys a standalone content-provider-api +
# Blazor GUI (no dashboard, no mongo). Both can exist on the same QNAP, but
# they default to overlapping ports (Blazor uses 12020) — if running both
# at once, change one of the FRONTEND_PORT/BLAZOR_PORT values below.
#
# Copy to .env.qnap-test and fill in real values. Never commit .env.qnap-test
# (only this .example is meant to be committed).

# ============================================
# MongoDB (test range: 27018, distinct from prod 27017)
# ============================================
QNAP_CONTAINER_DATA_PATH=/share/ContainerData
MONGODB_TEST_PORT=27018
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me
MONGODB_URI=mongodb://change_me:change_me@localhost:27018/chad?authSource=admin

# ============================================
# Content Provider API
# ============================================
# Host path holding real repo data — must be the PARENT of "repos/", not
# repos/ itself (see documentation/content-provider/next-tasks/
# qnap-test-deployment.md §6). Same real data net-content-provider's own
# QNAP-TEST scripts use.
CP_REPOS_HOST_PATH=/share/Dropbox
CONTENT_PROVIDER_API_PORT=12024

# ============================================
# Dashboard frontend (12025 — avoids net-content-provider's own Blazor on 12020)
# ============================================
FRONTEND_PORT=12025
DATABASE_URL=file:/app/data/dev.db

# ============================================
# QNAP address + SSH (used by 06_qnap_ssh/*_test.sh — never hardcode in scripts)
# ============================================
QNAP_PUBLIC_HOST=100.117.139.83
QNAP_SSH_HOST=100.117.139.83
QNAP_SSH_PORT=22
QNAP_SSH_USERNAME=change_me
QNAP_REPO_DIR=change_me
QNAP_SSH_PASSWORD=

# ============================================
# Console CLI — OpenAI key
# ============================================
OPENAI_API_KEY=change_me

# ============================================
# App metadata
# ============================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_NAME=Personal Dashboard
NEXT_PUBLIC_APP_URL=http://100.117.139.83:12025
