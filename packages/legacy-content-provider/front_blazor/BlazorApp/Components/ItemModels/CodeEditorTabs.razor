@using BackendAdapters.Names
@using BackendAdapters.Models
@using BackendAdapters.Workers
@inject BackendAdapter Backend

@code {
    [Parameter]
    public string Code { get; set; } = "";

    [Parameter]
    public EventCallback<string> CodeChanged { get; set; }

    [Parameter]
    public ItemModel? Item { get; set; }

    private string ActiveTab = "preview";
    private string editorCode = "";
    private string saveMessage = "";
    private string saveMessageClass = "";

    protected override void OnParametersSet()
    {
        // When switching to edit tab, initialize editor with current code
        if (ActiveTab == "edit")
        {
            editorCode = Code;
        }
    }

    private void SwitchTab(string tabName)
    {
        ActiveTab = tabName;
        saveMessage = "";
        
        // When switching to edit tab, initialize editor with current code
        if (tabName == "edit")
        {
            editorCode = Code;
        }
    }

    private string GetTabClass(string tabName)
    {
        return tabName == ActiveTab ? "code-tab-active" : "";
    }

    private void OnEditorCodeChanged(string newCode)
    {
        editorCode = newCode;
    }

    private async Task SaveAsync()
    {
        if (Item == null)
        {
            saveMessage = "Błąd: brak danych elementu";
            saveMessageClass = "text-danger";
            return;
        }

        try
        {
            var args = new[] {
                SNames.RepoService,
                SNames.ItemWorker,
                SNames.Put,
                Item.AdrTuple.Repo,
                Item.AdrTuple.Loca,
                Item.Type,
                Item.Name,
                editorCode
            };

            string result = await Backend.InvokeStringArgsApi(args);
            
            saveMessage = "✅ Zapisano!";
            saveMessageClass = "text-success";

            // Notify parent about code change
            if (CodeChanged.HasDelegate)
            {
                await CodeChanged.InvokeAsync(editorCode);
            }

            // Clear message after 3 seconds
            await Task.Delay(3000);
            saveMessage = "";
        }
        catch (Exception ex)
        {
            saveMessage = $"❌ Błąd zapisu: {ex.Message}";
            saveMessageClass = "text-danger";
        }
    }
}

<div class="code-tabs-toolbar">
    <button @onclick='() => SwitchTab("preview")' class='btn btn-sm code-tab-btn @GetTabClass("preview")'>🧾 Podgląd</button>
    <button @onclick='() => SwitchTab("edit")' class='btn btn-sm code-tab-btn @GetTabClass("edit")'>✏️ Edytor</button>
    @if (ActiveTab == "edit")
    {
        <button @onclick='SaveAsync' class='btn btn-sm code-tab-btn code-save-btn'>💾 Zapisz</button>
    }
    @if (!string.IsNullOrEmpty(saveMessage))
    {
        <span class="@saveMessageClass save-message">@saveMessage</span>
    }
</div>

<div class="code-tab-content">
    @if (ActiveTab == "preview")
    {
        <textarea readonly class="code-textarea">@Code</textarea>
    }
    else if (ActiveTab == "edit")
    {
        <SimpleCodeEditor Code="@editorCode" CodeChanged="OnEditorCodeChanged" />
    }
</div>

<style>
    .code-tabs-toolbar {
        display: flex;
        gap: 4px;
        align-items: center;
        margin-bottom: 4px;
    }

    .code-tab-btn {
        border: 1px solid #000;
        background-color: #fff;
        color: #000;
        border-radius: 4px 4px 0 0;
        padding: 3px 8px;
        font-size: 0.875rem;
        line-height: 1.25;
        height: auto;
    }

    .code-tab-btn:hover,
    .code-tab-btn:focus {
        background-color: #f5f5f5;
        border-color: #000;
        color: #000;
    }

    .code-tab-btn.code-tab-active {
        background-color: #e9e9e9;
        color: #000;
        border-color: #000;
        border-bottom-color: #e9e9e9;
    }

    .code-save-btn {
        background-color: #28a745;
        color: #fff;
        border-color: #28a745;
        margin-left: auto;
    }

    .code-save-btn:hover,
    .code-save-btn:focus {
        background-color: #218838;
        border-color: #1e7e34;
        color: #fff;
    }

    .save-message {
        font-size: 0.875rem;
        font-weight: 500;
        margin-left: 8px;
    }

    .code-tab-content {
        margin-top: 4px;
    }

    .code-textarea {
        border: 1px solid #000;
        background-color: #fff;
        color: #000;
        border-radius: 4px;
        padding: 8px;
        font-size: 0.875rem;
        line-height: 1.35;
        width: 100%;
        min-height: calc(100vh - 350px);
        box-sizing: border-box;
        font-family: Consolas, monospace;
        resize: vertical;
    }

    .code-textarea:focus {
        border-color: #000;
        outline: none;
    }
</style>