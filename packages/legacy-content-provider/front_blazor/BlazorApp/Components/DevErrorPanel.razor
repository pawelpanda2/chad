@* 
    Developer Error/Debug Panel for BlazorApp
    Right-side sliding panel with tabs for Configuration and AI logs
    This component displays detailed error information, logs, and diagnostics
    to help debug issues that would otherwise show only "An unhandled error has occurred. Reload"
*@

<div class="dev-panel-overlay" style="@OverlayStyle">
    @* Collapsed handle - visible when panel is closed *@
    @if (!IsExpanded)
    {
        <div class="dev-panel-handle" @onclick="ToggleExpanded" style="@HandleStyle">
            <span>🔧</span>
            <span class="dev-handle-text">Dev</span>
            @if (ErrorCount > 0 || WarningCount > 0)
            {
                <span class="dev-handle-badge">@(ErrorCount + WarningCount)</span>
            }
        </div>
    }

    @* Expanded panel - slides from right *@
    @if (IsExpanded)
    {
        <div class="dev-panel-container" style="@PanelStyle">
            @* Header bar *@
            <div class="dev-panel-header">
                <div class="dev-panel-header-left">
                    <span class="dev-panel-title">🔧 Dev Panel</span>
                    @if (ErrorCount > 0)
                    {
                        <span class="dev-badge dev-badge-error">@ErrorCount</span>
                    }
                    @if (WarningCount > 0)
                    {
                        <span class="dev-badge dev-badge-warning">@WarningCount</span>
                    }
                </div>
                <div class="dev-panel-header-right">
                    <span class="dev-api-info">@ConfigInfo</span>
                    <button class="dev-btn" @onclick="ClearLogs" title="Clear logs">🗑️ Clear</button>
                    <button class="dev-btn" @onclick="ExportLogs" title="Export logs">📋 Export</button>
                    <button class="dev-btn dev-btn-close" @onclick="ToggleExpanded" title="Close panel">✕</button>
                </div>
            </div>

            @* Tabs *@
            <div class="dev-panel-tabs">
                <button class="dev-tab @(ActiveTab == "requests" ? "active" : "")" @onclick="@(() => SetTab("requests"))">🌐 Requests @(RequestCount > 0 ? $"({RequestCount})" : "")</button>
                <button class="dev-tab @(ActiveTab == "configuration" ? "active" : "")" @onclick="@(() => SetTab("configuration"))">⚙️ Configuration</button>
                <button class="dev-tab @(ActiveTab == "logs" ? "active" : "")" @onclick="@(() => SetTab("logs"))">📋 Logs (@TotalCount)</button>
                <button class="dev-tab @(ActiveTab == "exceptions" ? "active" : "")" @onclick="@(() => SetTab("exceptions"))">⚠️ Exceptions @(ExceptionCount > 0 ? $"({ExceptionCount})" : "")</button>
                <button class="dev-tab @(ActiveTab == "ai-logs" ? "active" : "")" @onclick="@(() => SetTab("ai-logs"))">🤖 AI Logs</button>
            </div>

            @* Tab Content *@
            <div class="dev-panel-content">
                @if (ActiveTab == "configuration")
                {
                    @* Configuration Tab *@
                    <div class="dev-tab-section">
                        <div class="dev-section-title">⚙️ Configuration</div>
                        <table class="dev-config-table">
                            <tr><td class="dev-config-label">ROOT ADDRESS:</td><td class="dev-config-value">@(RootAddress ?? "NULL")</td></tr>
                            <tr><td class="dev-config-label">URI:</td><td class="dev-config-value">@CurrentUrl</td></tr>
                            <tr><td class="dev-config-label">BASE:</td><td class="dev-config-value">@CurrentBaseUri</td></tr>
                        </table>
                    </div>
                }
                else if (ActiveTab == "logs")
                {
                    @* Logs Tab (same as configuration but focused on logs) *@
                    <div class="dev-tab-section">
                        <div class="dev-section-title">📋 All Logs</div>
                        
                        @* Filter buttons *@
                        <div class="dev-filters">
                            <button class="dev-filter-btn @(ActiveFilter == null ? "active" : "")" @onclick="() => SetFilter(null)">All (@TotalCount)</button>
                            <button class="dev-filter-btn @(ActiveFilter == DevLogLevel.Info ? "active" : "")" @onclick="() => SetFilter(DevLogLevel.Info)">Info (@InfoCount)</button>
                            <button class="dev-filter-btn @(ActiveFilter == DevLogLevel.Warning ? "active" : "")" @onclick="() => SetFilter(DevLogLevel.Warning)">Warn (@WarningCount)</button>
                            <button class="dev-filter-btn @(ActiveFilter == DevLogLevel.Error ? "active" : "")" @onclick="() => SetFilter(DevLogLevel.Error)">Error (@ErrorCount)</button>
                            <button class="dev-filter-btn @(ActiveFilter == DevLogLevel.Critical ? "active" : "")" @onclick="() => SetFilter(DevLogLevel.Critical)">Critical (@CriticalCount)</button>
                        </div>

                        <div class="dev-logs">
                            @if (!FilteredLogs.Any())
                            {
                                <div class="dev-no-logs">No log entries</div>
                            }
                            else
                            {
                                @foreach (var log in FilteredLogs)
                                {
                                    <div class="dev-log-entry dev-level-@log.Level.ToString().ToLower()">
                                        <div class="dev-log-header">
                                            <span class="dev-log-time">@log.Timestamp.ToString("HH:mm:ss.fff")</span>
                                            <span class="dev-log-level">@log.Level</span>
                                            <span class="dev-log-source">@log.Source</span>
                                        </div>
                                        <div class="dev-log-message">@log.Message</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
                else if (ActiveTab == "requests")
                {
                    @* Requests Tab *@
                    <div class="dev-tab-section">
                        <div class="dev-section-title">🌐 HTTP Requests</div>
                        <div style="margin-bottom: 12px;">
                            <button class="dev-btn" @onclick="ClearRequests">🗑️ Clear Requests</button>
                        </div>
                        
                        @if (!DevRequestLogStore.Entries.Any())
                        {
                            <div class="dev-no-logs">No requests yet</div>
                        }
                        else
                        {
                            @foreach (var entry in DevRequestLogStore.Entries)
                            {
                                <div class="dev-request-card">
                                    <div class="dev-request-header">
                                        <span class="dev-request-id">REQUEST #@entry.Id</span>
                                        <span class="dev-request-time">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</span>
                                        <span class="dev-request-duration">@entry.DurationMs ms</span>
                                    </div>
                                    <div class="dev-request-method-url">
                                        <span class="dev-request-method">@entry.Method</span>
                                        <span class="dev-request-url">@entry.Url</span>
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(entry.RequestBody))
                                    {
                                        <div class="dev-request-detail">
                                            <strong>REQUEST BODY:</strong>
                                            <pre class="dev-log-pre">@entry.RequestBody</pre>
                                        </div>
                                    }
                                    
                                    @if (!string.IsNullOrEmpty(entry.Error))
                                    {
                                        <div class="dev-request-detail dev-request-error">
                                            <strong>ERROR:</strong>
                                            <pre class="dev-log-pre dev-stack">@entry.Error</pre>
                                        </div>
                                    }
                                    else
                                    {
                                        @if (entry.StatusCode.HasValue)
                                        {
                                            <div class="dev-request-detail">
                                                <strong>RESPONSE:</strong>
                                                <span class="dev-request-status">@(entry.StatusCode) @(entry.StatusText)</span>
                                                @if (!string.IsNullOrEmpty(entry.ResponseBody))
                                                {
                                                    var responseBodyExpanded = responseBodyExpandedDict.ContainsKey(entry.Id) && responseBodyExpandedDict[entry.Id];
                                                    var displayBody = responseBodyExpanded && entry.ResponseBody.Length > 1000 
                                                        ? entry.ResponseBody 
                                                        : Truncate(entry.ResponseBody, 1000);
                                                    
                                                    <div class="dev-response-body-container">
                                                        <pre class="dev-log-pre">@GetFormattedResponseBody(displayBody)</pre>
                                                        <div class="dev-response-actions">
                                                            <button class="dev-btn dev-btn-toggle-full" @onclick="() => CopyResponseBody(entry.ResponseBody)">
                                                                copy
                                                            </button>
                                                            @if (entry.ResponseBody.Length > 1000)
                                                            {
                                                                <button class="dev-btn dev-btn-toggle-full" @onclick="() => ToggleResponseBody(entry.Id)">
                                                                    @(responseBodyExpanded ? "Show less" : "Show full response (" + entry.ResponseBody.Length + " chars)")
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>
                }
                else if (ActiveTab == "exceptions")
                {
                    @* Exceptions Tab *@
                    <div class="dev-tab-section">
                        <div class="dev-section-title">⚠️ Exceptions & Errors</div>
                        <div style="margin-bottom: 12px;">
                            <button class="dev-btn" @onclick="ClearExceptions">🗑️ Clear Exceptions</button>
                        </div>
                        
                        @if (!ExceptionLogs.Any())
                        {
                            <div class="dev-no-logs">No exceptions captured</div>
                        }
                        else
                        {
                            var exceptionList = ExceptionLogs.ToList();
                            for (var idx = 0; idx < exceptionList.Count; idx++)
                            {
                                var entry = exceptionList[idx];
                                var isBackendError = entry.Source.StartsWith("Backend:");
                                var entryId = exceptionList.Count - idx;
                                var formattedError = isBackendError ? FormatBackendError(entry) : null;
                                
                                <div class="dev-exception-card @(isBackendError ? "dev-exception-backend" : "")">
                                    <div class="dev-exception-header">
                                        <span class="dev-exception-id">
                                            @(isBackendError ? "BACKEND ERROR" : "EXCEPTION") #@(entryId)
                                        </span>
                                        <span class="dev-exception-time">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</span>
                                    </div>
                                    
                                    @if (isBackendError && formattedError != null)
                                    {
                                        @* Human-readable formatted backend error *@
                                        <div class="dev-formatted-error">
                                            @* SOURCE section *@
                                            <div class="dev-error-section dev-error-section-bordered">
                                                <div class="dev-error-subtitle">SOURCE</div>
                                                <div class="dev-error-detail">
                                                    <span class="dev-error-detail-label">Time:</span>
                                                    <span class="dev-error-detail-value">@formattedError.Time</span>
                                                </div>
                                                <div class="dev-error-detail">
                                                    <span class="dev-error-detail-label">Call:</span>
                                                    <span class="dev-error-detail-value">@formattedError.MethodCall</span>
                                                </div>
                                            </div>
                                            
                                            @* ANALYSIS section *@
                                            <div class="dev-error-section dev-error-section-bordered">
                                                <div class="dev-error-subtitle">ANALYSIS</div>
                                                @if (!string.IsNullOrEmpty(formattedError.WrapperType))
                                                {
                                                    <div class="dev-error-detail">
                                                        <span class="dev-error-detail-label">Wrapper:</span>
                                                        <span class="dev-error-detail-value">@formattedError.WrapperType</span>
                                                    </div>
                                                }
                                                <div class="dev-error-detail">
                                                    <span class="dev-error-detail-label">Type:</span>
                                                    <span class="dev-error-detail-value dev-error-type">@formattedError.ErrorType</span>
                                                </div>
                                                <div class="dev-error-detail">
                                                    <span class="dev-error-detail-label">Message:</span>
                                                    <span class="dev-error-detail-value">@formattedError.ErrorMessage</span>
                                                </div>
                                                @if (!string.IsNullOrEmpty(formattedError.ErrorPath))
                                                {
                                                    <div class="dev-error-detail">
                                                        <span class="dev-error-detail-label">Path:</span>
                                                        <span class="dev-error-detail-value dev-error-path">@formattedError.ErrorPath</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(formattedError.File) || !string.IsNullOrEmpty(formattedError.Line))
                                                {
                                                    <div class="dev-error-detail">
                                                        <span class="dev-error-detail-label">Location:</span>
                                                        <span class="dev-error-detail-value">
                                                            @formattedError.File
                                                            @if (!string.IsNullOrEmpty(formattedError.Line))
                                                            {
                                                                <text> Line @formattedError.Line</text>
                                                            }
                                                        </span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(formattedError.Method))
                                                {
                                                    <div class="dev-error-detail">
                                                        <span class="dev-error-detail-label">Method:</span>
                                                        <span class="dev-error-detail-value">@formattedError.Method</span>
                                                    </div>
                                                }
                                                @if (formattedError.CallChain.Any())
                                                {
                                                    <div class="dev-error-detail">
                                                        <span class="dev-error-detail-label">Call chain:</span>
                                                        <span class="dev-error-detail-value">@string.Join(" → ", formattedError.CallChain.Take(2))</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(formattedError.LikelyCause))
                                                {
                                                    <div class="dev-error-detail dev-error-cause">
                                                        <span class="dev-error-detail-label">Likely cause:</span>
                                                        <span class="dev-error-detail-value">@formattedError.LikelyCause</span>
                                                    </div>
                                                }
                                            </div>
                                            
                                            @* Raw Details Toggle *@
                                            <div class="dev-raw-details-toggle">
                                                @if (rawDetailsExpanded.ContainsKey(entryId))
                                                {
                                                    <button class="dev-btn dev-btn-raw-toggle" @onclick="() => ToggleRawDetails(entryId)">
                                                        <span>−</span> Hide raw details
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="dev-btn dev-btn-raw-toggle" @onclick="() => ToggleRawDetails(entryId)">
                                                        <span>+</span> Show raw details
                                                    </button>
                                                }
                                            </div>
                                            
                                            @* Raw Details (collapsible) *@
                                    @if (rawDetailsExpanded.ContainsKey(entryId))
                                    {
                                        <div class="dev-raw-details">
                                            <div class="dev-error-subtitle">RAW DETAILS (Original Backend Response)</div>
                                            @if (!string.IsNullOrEmpty(formattedError.RawOriginalLog))
                                            {
                                                <pre class="dev-log-pre dev-raw-json">@FormatRawLogForDisplay(formattedError.RawOriginalLog)</pre>
                                            }
                                            else if (!string.IsNullOrEmpty(formattedError.RawStackTrace))
                                            {
                                                <div class="dev-error-detail" style="margin-top: 12px;">
                                                    <strong>Stack Trace:</strong>
                                                    <pre class="dev-log-pre dev-stack">@formattedError.RawStackTrace</pre>
                                                </div>
                                            }
                                        </div>
                                    }
                                        </div>
                                    }
                                    else
                                    {
                                        @* Fallback for non-backend errors or format failures *@
                                        <div class="dev-exception-source">
                                            <strong>source:</strong> @entry.Source
                                        </div>
                                        
                                        @if (!string.IsNullOrEmpty(entry.ExceptionType))
                                        {
                                            <div class="dev-exception-detail">
                                                <strong>ExceptionType:</strong> @entry.ExceptionType
                                            </div>
                                        }
                                        
                                        <div class="dev-exception-detail">
                                            <strong>Message:</strong> @entry.Message
                                        </div>
                                        
                                        @if (!string.IsNullOrEmpty(entry.StackTrace))
                                        {
                                            <div class="dev-exception-detail">
                                                <strong>StackTrace:</strong>
                                                <pre class="dev-log-pre dev-stack">@Truncate(entry.StackTrace, 2000)</pre>
                                            </div>
                                        }
                                        
                                        @if (!string.IsNullOrEmpty(entry.AdditionalData))
                                        {
                                            <div class="dev-exception-detail">
                                                <strong>Context:</strong>
                                                <pre class="dev-log-pre">@entry.AdditionalData</pre>
                                            </div>
                                        }
                                        
                                        @* Raw details toggle for non-backend errors *@
                                        <div class="dev-raw-details-toggle">
                                            @if (rawDetailsExpanded.ContainsKey(entryId))
                                            {
                                                <button class="dev-btn dev-btn-raw-toggle" @onclick="() => ToggleRawDetails(entryId)">
                                                    <span>−</span> Hide raw details
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="dev-btn dev-btn-raw-toggle" @onclick="() => ToggleRawDetails(entryId)">
                                                    <span>+</span> Show raw details
                                                </button>
                                            }
                                        </div>
                                        
                                        @if (rawDetailsExpanded.ContainsKey(entryId))
                                        {
                                            <div class="dev-raw-details">
                                                <div class="dev-error-subtitle">RAW DETAILS</div>
                                                <pre class="dev-log-pre">ExceptionType: @entry.ExceptionType
Message: @entry.Message
StackTrace: @entry.StackTrace
AdditionalData: @entry.AdditionalData</pre>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>
                }
                else if (ActiveTab == "ai-logs")
                {
                    @* AI Logs Tab *@
                    <div class="dev-tab-section">
                        <div class="dev-section-title">🤖 AI Logs</div>
                        <div class="dev-ai-logs-info">
                            <p>No AI logs yet.</p>
                            <p class="dev-ai-hint">This section will contain diagnostic logs for AI/Cline to help analyze component behavior, data flow, and potential issues.</p>
                        </div>
                        <div class="dev-ai-actions">
                            <button class="dev-btn" @onclick="ClearAiLogs">🗑️ Clear AI Logs</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@using BackendAdapters.DevLogs
@using System.Text.Json
@using System.Text.Json.Nodes

@using BlazorApp.Services

@code {
    [Inject] private NavigationManager? Navigation { get; set; }
    [Inject] private DevLogService? DevLogService { get; set; }
    [Inject] private BackendErrorFormatter? ErrorFormatter { get; set; }
    [Inject] private IJSRuntime? JS { get; set; }
    
    private bool IsExpanded { get; set; } = false;
    private string ActiveTab { get; set; } = "configuration";
    private DevLogLevel? ActiveFilter { get; set; } = null;
    
    // Tracks which exception raw details are expanded (key = entryId)
    private Dictionary<int, bool> rawDetailsExpanded { get; set; } = new();
    
    // Tracks which response body is expanded (key = entry.Id)
    private Dictionary<int, bool> responseBodyExpandedDict { get; set; } = new();
    private string CurrentUrl => Navigation?.Uri ?? "(unknown)";
    private string CurrentBaseUri => Navigation?.BaseUri ?? "(unknown)";
    private string RootAddress => GetRootAddress();
    private string ConfigInfo => DevLogService?.ContentProviderApiUrl != null
        ? $"API: {DevLogService.ContentProviderApiUrl}" 
        : "API: (not set)";
    
    private int RequestCount => DevRequestLogStore.Entries.Count;
    private int ExceptionCount => (DevLogService?.GetCounts().error ?? 0) + (DevLogService?.GetCounts().critical ?? 0);
    
    private IEnumerable<DevLogEntry> FilteredLogs =>
        ActiveFilter.HasValue 
            ? DevLogService?.GetLogsByLevel(ActiveFilter.Value) ?? Enumerable.Empty<DevLogEntry>()
            : DevLogService?.GetLogs() ?? Enumerable.Empty<DevLogEntry>();
    
    private IReadOnlyList<DevLogEntry> Logs => DevLogService?.GetLogs() ?? new List<DevLogEntry>();
    private IReadOnlyList<DevLogEntry> ExceptionLogs => DevLogService?.GetErrors() ?? new List<DevLogEntry>();
    private int TotalCount => DevLogService?.GetCounts().info + DevLogService?.GetCounts().warning + DevLogService?.GetCounts().error + DevLogService?.GetCounts().critical ?? 0;
    private int InfoCount => DevLogService?.GetCounts().info ?? 0;
    private int WarningCount => DevLogService?.GetCounts().warning ?? 0;
    private int ErrorCount => DevLogService?.GetCounts().error ?? 0;
    private int CriticalCount => DevLogService?.GetCounts().critical ?? 0;
    
    protected override void OnInitialized()
    {
        if (DevLogService != null)
        {
            DevLogService.OnLogChanged += StateHasChanged;
        }
        DevRequestLogStore.OnChanged += OnRequestLogChanged;
    }
    
    private void OnRequestLogChanged()
    {
        InvokeAsync(StateHasChanged);
    }
    
    private void ToggleExpanded()
    {
        IsExpanded = !IsExpanded;
        StateHasChanged();
    }
    
    private void SetTab(string tab)
    {
        ActiveTab = tab;
        StateHasChanged();
    }
    
    private void SetFilter(DevLogLevel? level)
    {
        ActiveFilter = level;
        StateHasChanged();
    }
    
    private void ClearLogs()
    {
        DevLogService?.Clear();
    }
    
    private void ClearAiLogs()
    {
        // Placeholder for AI logs clear
        Console.WriteLine("[DevErrorPanel] Clear AI Logs clicked");
    }
    
    private void ClearRequests()
    {
        DevRequestLogStore.Clear();
    }
    
    private void ClearExceptions()
    {
        DevLogService?.ClearExceptions();
    }
    
    private void ExportLogs()
    {
        var json = DevLogService?.ExportLogsAsJson();
        if (!string.IsNullOrEmpty(json))
        {
            Console.WriteLine($"[DevErrorPanel] Exported logs:\n{json}");
        }
    }
    
    private string Truncate(string value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return value;
        return value.Length <= maxLength ? value : value.Substring(0, maxLength) + "...";
    }
    
    private string GetRootAddress()
    {
        var uri = Navigation?.Uri;
        if (string.IsNullOrEmpty(uri)) return "NULL";
        
        var baseUri = Navigation?.BaseUri ?? "/";
        if (uri.StartsWith(baseUri))
        {
            var path = uri.Substring(baseUri.Length);
            if (string.IsNullOrEmpty(path)) return "ROOT (/)";
            return path;
        }
        return uri;
    }
    
    /// <summary>
    /// Format a log entry into a human-readable backend error.
    /// Returns null if the entry cannot be formatted (fallback to raw display).
    /// The raw original log from the backend is passed through to preserve the original text.
    /// </summary>
    private FormattedBackendError? FormatBackendError(DevLogEntry entry)
    {
        try
        {
            if (ErrorFormatter == null) return null;
            
            // The raw original log - this is the exact text from the backend
            // It must be preserved unchanged for the Raw Details section
            string rawOriginalLog = entry.RawOriginalLog ?? string.Empty;
            
            // Extract source (remove "Backend:" prefix)
            string source = entry.Source;
            if (source.StartsWith("Backend:", StringComparison.OrdinalIgnoreCase))
            {
                source = source.Substring("Backend:".Length);
            }
            
            // Try to parse the raw JSON directly from RawOriginalLog
            BackendErrorInfo? errorInfo = null;
            string[] requestArgs = Array.Empty<string>();
            
            if (!string.IsNullOrEmpty(rawOriginalLog))
            {
                // Remove "error:" prefix if present for parsing
                string jsonToParse = rawOriginalLog;
                if (jsonToParse.StartsWith("error:", StringComparison.OrdinalIgnoreCase))
                {
                    jsonToParse = jsonToParse.Substring("error:".Length);
                }
                
                // Try to parse as JSON
                try
                {
                    var jsonDoc = JsonNode.Parse(jsonToParse);
                    if (jsonDoc != null)
                    {
                        errorInfo = ParseBackendErrorInfoFromJson(jsonDoc);
                    }
                }
                catch
                {
                    // Not JSON or parsing failed
                }
            }
            
            // Always try to extract request args from AdditionalData (this is where BackendAdapter stores them)
            if (!string.IsNullOrEmpty(entry.AdditionalData))
            {
                var argsMatch = System.Text.RegularExpressions.Regex.Match(entry.AdditionalData, @"Request args:\s*\[(.*?)\]");
                if (argsMatch.Success)
                {
                    requestArgs = argsMatch.Groups[1].Value.Split(',').Select(a => a.Trim()).ToArray();
                    
                    // Diagnostic logging
                    Console.WriteLine($"[DevErrorPanel] Extracted request args from AdditionalData:");
                    Console.WriteLine($"[DevErrorPanel]   requestArgs.Count = {requestArgs.Length}");
                    for (int i = 0; i < requestArgs.Length; i++)
                    {
                        Console.WriteLine($"[DevErrorPanel]   arg{i} = {requestArgs[i]}");
                    }
                    var builtCall = BackendErrorFormatter.BuildMethodCall(requestArgs);
                    Console.WriteLine($"[DevErrorPanel]   Built call = {builtCall}");
                }
            }
            
            // If we couldn't parse errorInfo from JSON, try to reconstruct from AdditionalData
            if (errorInfo == null && !string.IsNullOrEmpty(entry.AdditionalData))
            {
                errorInfo = new BackendErrorInfo
                {
                    MessageType = entry.ExceptionType ?? string.Empty,
                    Message = entry.ExceptionMessage ?? entry.Message ?? string.Empty,
                    StackTrace = entry.StackTrace,
                    Source = source
                };
                
                // Try to extract target site
                var targetMatch = System.Text.RegularExpressions.Regex.Match(entry.AdditionalData, @"TargetSite:\s*(.+)");
                if (targetMatch.Success)
                {
                    errorInfo.TargetSite = targetMatch.Groups[1].Value.Trim();
                }
                
                // Try to extract inner exception info from the full details
                var innerMatch = System.Text.RegularExpressions.Regex.Match(entry.AdditionalData, @"Inner Exception:");
                if (innerMatch.Success)
                {
                    // There's an inner exception - try to parse it
                    var innerTypeMatch = System.Text.RegularExpressions.Regex.Match(entry.AdditionalData, @"Inner Exception:\s*\n\s*ExceptionType:\s*(.+)");
                    var innerMsgMatch = System.Text.RegularExpressions.Regex.Match(entry.AdditionalData, @"Inner Exception:\s*\n\s*.*\n\s*Message:\s*(.+)");
                    
                    if (innerTypeMatch.Success || innerMsgMatch.Success)
                    {
                        errorInfo.InnerException = new BackendErrorInfo
                        {
                            MessageType = innerTypeMatch.Success ? innerTypeMatch.Groups[1].Value.Trim() : string.Empty,
                            Message = innerMsgMatch.Success ? innerMsgMatch.Groups[1].Value.Trim() : string.Empty
                        };
                    }
                }
            }
            
            if (errorInfo != null)
            {
                return ErrorFormatter.Format(errorInfo, source, entry.Timestamp, requestArgs, rawOriginalLog);
            }
            
            // Fallback: try with just the basic info
            string fallbackSource = entry.Source;
            if (fallbackSource.StartsWith("Backend:", StringComparison.OrdinalIgnoreCase))
            {
                fallbackSource = fallbackSource.Substring("Backend:".Length);
            }
            
            return ErrorFormatter.FormatSimple(
                entry.ExceptionMessage ?? entry.Message ?? "Unknown error",
                fallbackSource,
                entry.Timestamp,
                Array.Empty<string>(),
                rawOriginalLog);
        }
        catch
        {
            // If formatting fails, return null to use fallback display
            return null;
        }
    }

    /// <summary>
    /// Parse BackendErrorInfo from JSON document (from rawOriginalLog)
    /// </summary>
    private BackendErrorInfo ParseBackendErrorInfoFromJson(JsonNode jsonDoc)
    {
        var errorInfo = new BackendErrorInfo
        {
            MessageType = jsonDoc["messageType"]?.GetValue<string>() ?? string.Empty,
            Message = jsonDoc["message"]?.GetValue<string>() ?? string.Empty,
            StackTrace = jsonDoc["stackTrace"]?.GetValue<string>(),
            TargetSite = jsonDoc["targetSite"]?.GetValue<string>(),
            Source = jsonDoc["source"]?.GetValue<string>()
        };

        // Parse innerException if present
        var innerExceptionNode = jsonDoc["innerException"];
        if (innerExceptionNode != null)
        {
            errorInfo.InnerException = new BackendErrorInfo
            {
                MessageType = innerExceptionNode["messageType"]?.GetValue<string>() ?? string.Empty,
                Message = innerExceptionNode["message"]?.GetValue<string>() ?? string.Empty,
                StackTrace = innerExceptionNode["stackTrace"]?.GetValue<string>(),
                TargetSite = innerExceptionNode["targetSite"]?.GetValue<string>(),
                Source = innerExceptionNode["source"]?.GetValue<string>()
            };
        }

        return errorInfo;
    }

    /// <summary>
    /// Extract request args from targetSite signature
    /// TargetSite format: "System.Object InvokeWithFewArgs(System.Object, System.Reflection.BindingFlags, ...)"
    /// We need to find the actual method call args from the stack trace
    /// </summary>
    private string[] ExtractRequestArgsFromTargetSite(string? targetSite)
    {
        // For now, return empty array - the actual args come from the log entry's AdditionalData
        return Array.Empty<string>();
    }
    
    /// <summary>
    /// Toggle the raw details section for a specific exception entry
    /// </summary>
    private void ToggleRawDetails(int entryId)
    {
        if (rawDetailsExpanded.ContainsKey(entryId))
        {
            rawDetailsExpanded.Remove(entryId);
        }
        else
        {
            rawDetailsExpanded[entryId] = true;
        }
        StateHasChanged();
    }
    
    /// <summary>
    /// Toggle the full response body display for a specific request entry
    /// </summary>
    private void ToggleResponseBody(int entryId)
    {
        if (responseBodyExpandedDict.ContainsKey(entryId))
        {
            responseBodyExpandedDict[entryId] = !responseBodyExpandedDict[entryId];
        }
        else
        {
            responseBodyExpandedDict[entryId] = true;
        }
        StateHasChanged();
    }

    /// <summary>
    /// Copy the response body to clipboard (formatted version)
    /// </summary>
    private async Task CopyResponseBody(string responseBody)
    {
        try
        {
            if (JS != null)
            {
                var formattedBody = GetFormattedResponseBody(responseBody);
                await JS.InvokeVoidAsync("navigator.clipboard.writeText", formattedBody);
                Console.WriteLine($"[DevErrorPanel] Response body copied to clipboard ({formattedBody.Length} chars)");
            }
            else
            {
                Console.WriteLine($"[DevErrorPanel] IJSRuntime not available, could not copy to clipboard");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DevErrorPanel] Failed to copy to clipboard: {ex.Message}");
        }
    }

    /// <summary>
    /// Format raw log for display in the Raw Details section.
    /// - Removes 'error:' prefix if present
    /// - Pretty-prints JSON if the content is JSON
    /// - Returns plain text otherwise
    /// </summary>
    private string FormatRawLogForDisplay(string rawLog)
    {
        if (string.IsNullOrEmpty(rawLog)) return string.Empty;

        var cleaned = rawLog;

        // Remove 'error:' prefix if present
        if (cleaned.StartsWith("error:", StringComparison.OrdinalIgnoreCase))
        {
            cleaned = cleaned.Substring("error:".Length);
        }

        // Try to pretty-print as JSON
        try
        {
            var jsonDoc = JsonNode.Parse(cleaned);
            if (jsonDoc != null)
            {
                var options = new JsonSerializerOptions { WriteIndented = true };
                return jsonDoc.ToJsonString(options);
            }
        }
        catch
        {
            // Not JSON, return as plain text
        }

        return cleaned;
    }

    /// <summary>
    /// Format response body for display.
    /// - If JSON, pretty-prints with indentation
    /// - If starts with a prefix ending with ':' (e.g. 'error:', 'warning:', 'response:'),
    ///   keeps the prefix on its own line and formats the JSON after it
    /// - Returns plain text otherwise
    /// </summary>
    private string GetFormattedResponseBody(string responseBody)
    {
        if (string.IsNullOrEmpty(responseBody)) return string.Empty;

        // Check for prefix ending with ':' (e.g. "error:", "warning:", "response:")
        string? prefix = null;
        string jsonToFormat = responseBody;

        var colonIndex = responseBody.IndexOf(':');
        if (colonIndex > 0 && colonIndex < responseBody.Length - 1 && responseBody[colonIndex + 1] == '{')
        {
            prefix = responseBody.Substring(0, colonIndex + 1);
            jsonToFormat = responseBody.Substring(colonIndex + 1);
        }

        // Try to pretty-print as JSON
        try
        {
            var jsonDoc = JsonNode.Parse(jsonToFormat);
            if (jsonDoc != null)
            {
                var options = new JsonSerializerOptions { WriteIndented = true };
                var formattedJson = jsonDoc.ToJsonString(options);
                if (prefix != null)
                {
                    return prefix + "\n" + formattedJson;
                }
                return formattedJson;
            }
        }
        catch
        {
            // Not JSON, return as plain text
        }

        return responseBody;
    }
    
