# Personal Dashboard - Environment Configuration
# Copy this file to .env and adjust values as needed
#
# For specific environments, use:
# - .env.02_local_mac        (local development on Mac)
# - .env.04_docker_mac       (Docker on Mac)
# - .env.05_docker_qnap_test (QNAP test environment)
# - .env.06_docker_qnap_prod (QNAP production environment)

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# ============================================
# Port Configuration
# ============================================
# Standard port ranges:
# - Dev/Test: 12080-12029
# - Prod:     12030-12039
#
# Port assignments:
# - Frontend (Next.js):     12080 (dev/test) / 12030 (prod)
# - Backend (API):          12023 (dev/test) / 12033 (prod)
# - Content Provider API:   12024 (dev/test) / 12034 (prod)

FRONTEND_PORT=12080
BACKEND_PORT=12023
CONTENT_PROVIDER_API_PORT=12024

# ============================================
# Content Provider API URL
# ============================================
# For local Mac (non-Docker): use localhost
# For Docker: use Docker network DNS name
CONTENT_PROVIDER_API_URL=http://localhost:12024

# ============================================
# Content Provider Root
# ============================================
# For local Mac: set dynamically in scripts
# For Docker: /app/cp-root
CONTENT_PROVIDER_ROOT=

# ============================================
# Database (Prisma)
# ============================================
# Local (non-docker) - SQLite:
DATABASE_URL=file:./dev.db

# Docker/QNAP - PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/personal_dashboard?schema=public

# ============================================
# Docker Settings
# ============================================
DOCKER_REGISTRY=
DOCKER_IMAGE_NAME=personal-dashboard

# ============================================
# QNAP SSH Settings
# ============================================
# SSH connection to QNAP
QNAP_SSH_HOST=<your-qnap-ip>
QNAP_SSH_PORT=22
QNAP_SSH_USERNAME=<your-username>

# QNAP repository directory (where the project is cloned)
QNAP_REPO_DIR=<path-to-repo-on-qnap>

# Project name for environment identification
ENV_PROJECT_NAME=personal-dashboard

# QNAP SSH password (optional - avoids interactive password prompt)
# Do not commit real password to version control!
# QNAP_SSH_PASSWORD=

# ============================================
# QNAP Docker Settings
# ============================================
QNAP_HOST=
QNAP_USER=admin

# ============================================
# Public Application Settings
# ============================================
NEXT_PUBLIC_APP_NAME=Personal Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:12080
