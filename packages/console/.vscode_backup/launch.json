{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug cli.ts",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "node",
			"runtimeArgs": ["--import", "tsx"],
			"args": ["${workspaceFolder}/src/cli.ts"],
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		}
	]
}