{
  "name": "cp-entry",
  "version": "0.0.0",
  "private": true,
  "description": "Public entry / router for Content Provider. Routes repo GUID -> backend (net-adapter | files | mongo | postgre) via config only. Dashboard/API must import cp-entry, never storage packages directly.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/backend-selection.test.js"
  },
  "dependencies": {
    "cp-core": "workspace:*",
    "cp-net-adapter": "workspace:*",
    "cp-files": "workspace:*",
    "cp-mongo": "workspace:*",
    "cp-postgre": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
