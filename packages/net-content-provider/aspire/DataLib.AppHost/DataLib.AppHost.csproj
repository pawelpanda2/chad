<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsAspireHost>true</IsAspireHost>
    <UserSecretsId>196fd130-c7af-468c-afad-9d991660329f</UserSecretsId>
    <!-- Suppress Aspire workload deprecation warning in .NET 10 -->
    <SuppressAspireWorkloadDeprecationError>true</SuppressAspireWorkloadDeprecationError>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\front_blazor\BlazorApp\BlazorApp.csproj" />
    <ProjectReference Include="..\..\api_charp\SharpContainerApi\SharpContainerApi.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.AppHost" Version="8.2.2" />
    <PackageReference Include="Microsoft.AspNetCore.DataProtection" Version="8.0.0" />
    <PackageReference Include="DotNetEnv" Version="3.1.1" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="8.0.2" />
  </ItemGroup>

</Project>