# Stage 1: Build Blazor
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build_blazor
WORKDIR /app
COPY ./08_projects/BlazorApp.sln ./
COPY ./08_projects/BlazorApp/BlazorApp.csproj ./BlazorApp/
COPY ./08_projects/BlazorComponent/BlazorComponent.csproj ./BlazorComponent/
COPY ./08_projects/BackendAdapters/BackendAdapters.csproj ./BackendAdapters/
RUN dotnet restore
COPY ./08_projects ./
RUN dotnet publish -c Release -o out ./BlazorApp/BlazorApp.csproj

# Stage 2: Build API
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build_api
WORKDIR /src
COPY 01_database 01_database/
COPY 02_settings 02_settings/
COPY 03_projects 03_projects/
COPY 04_registrations 04_registrations/
COPY 05_projects 05_projects/
RUN dotnet restore '05_projects/PublicWebApi/PublicWebApi.csproj'
WORKDIR /src/05_projects/PublicWebApi
RUN dotnet build 'PublicWebApi.csproj' -c Release -o /app/build
RUN dotnet publish 'PublicWebApi.csproj' -c Release -o /app/publish

# Stage 3: Final image with nginx and API
FROM nginx:1.23.0-alpine AS final
WORKDIR /app

# Nginx config and Blazor static files
COPY ./08_projects/nginx.conf /etc/nginx/nginx.conf
COPY --from=build_blazor /app/out/wwwroot /usr/share/nginx/html

# API files
COPY --from=build_api /app/publish /app/api
COPY 02_settings /app/02_settings/
COPY 01_database /app/01_database/

# Install .NET runtime for API
RUN apk add --no-cache icu-libs \
    && apk add --no-cache --virtual .build-deps curl \
    && curl -SL --output dotnet.tar.gz https://dotnetcli.azureedge.net/dotnet/Runtime/8.0.0/dotnet-runtime-8.0.0-linux-musl-x64.tar.gz \
    && mkdir -p /usr/share/dotnet \
    && tar -zxf dotnet.tar.gz -C /usr/share/dotnet \
    && rm dotnet.tar.gz \
    && apk del .build-deps

ENV DOTNET_ROOT=/usr/share/dotnet
ENV PATH=$PATH:/usr/share/dotnet

EXPOSE 5156 6603

# Skrypt startowy uruchamiający oba serwisy
COPY start.sh /start.sh
RUN chmod +x /start.sh

# ENTRYPOINT ["/start.sh"]
ENTRYPOINT sh -c "dotnet /app/api/PublicWebApi.dll & nginx -g 'daemon off;'"
