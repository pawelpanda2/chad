# ================================
# BUILD STAGE (amd64)
# ================================
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /app

# Copy the entire front_blazor directory to preserve relative paths
COPY ./front_blazor ./

# Fix the .sln file by removing the BlazorAppTests reference
# The test project was removed but the .sln still references it
RUN sed -i '/BlazorAppTests/d' ./BlazorApp/BlazorApp.sln

# Bake the correct backend API URL into wwwroot/appsettings.json for this
# build's target environment. This is the ONLY mechanism that actually
# works: BlazorApp/Program.cs also tries Environment.GetEnvironmentVariable
# at runtime, but Blazor WebAssembly has no real OS environment in the
# browser — that call is always null once deployed as static files behind
# nginx (confirmed 2026-07-10, not assumed). builder.Configuration reads
# wwwroot/appsettings.json at WASM startup, which is what actually resolves
# ContentProviderApiUrl. Same sed-based file-edit pattern already used
# above for the .sln fix, not a new mechanism.
ARG CONTENT_PROVIDER_API_URL=http://localhost:12024
RUN sed -i "s#\"ContentProviderApiUrl\": \".*\"#\"ContentProviderApiUrl\": \"${CONTENT_PROVIDER_API_URL}\"#" \
    ./BlazorApp/wwwroot/appsettings.json

# Use buildx cache mounts - massive speedup
RUN --mount=type=cache,id=nuget,target=/root/.nuget/packages \
    dotnet restore ./BlazorApp/BlazorApp.sln

# Publish
RUN --mount=type=cache,id=nuget,target=/root/.nuget/packages \
    dotnet publish -c Release -o out ./BlazorApp/BlazorApp.csproj

# ================================
# RUNTIME stage
# ================================
FROM nginx:1.23.0-alpine

# Git build arguments
ARG GIT_COMMIT=unknown
ARG GIT_COMMIT_SHORT=unknown
ARG BUILD_DATE=unknown
ARG GIT_REMOTE_URL=unknown

# OCI labels
LABEL org.opencontainers.image.revision=$GIT_COMMIT
LABEL org.opencontainers.image.created=$BUILD_DATE
LABEL org.opencontainers.image.source=$GIT_REMOTE_URL
LABEL content-provider.git.short=$GIT_COMMIT_SHORT

WORKDIR /app
EXPOSE 5156 7262

COPY ./front_blazor/nginx.conf /etc/nginx/nginx.conf
COPY --from=build /app/out/wwwroot /usr/share/nginx/html
