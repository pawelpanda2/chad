# QNAP TEST environment for the backend API (cp-api-test).
# Copy to .env on the QNAP host (or pass via docker run -e) before running
# 03_scripts/qnap/deploy_qnap_test.sh. Never commit the real .env.
#
# CONFIRMED REQUIRED (verified by reading the actual C# code, 2026-07-10):
# only PreparerModule__NoSqlRepoSearchPaths__0 is ever read
# (SharpContainerApi/AA_public/ConfigNames.cs -> DefaultRegistration.cs).
# It must point at the path INSIDE the container where repos are mounted.
PreparerModule__NoSqlRepoSearchPaths__0=/data/repos

# Host-side path on the QNAP — used by the deploy scripts to build the bind
# mount ($QNAP_REPOS_HOST_PATH:$CONTAINER_REPOS_PATH), NOT read by the .NET
# app itself.
#
# IMPORTANT (confirmed 2026-07-10 against real local Dropbox data, and
# confirmed with the user this is intentional existing behavior, not a bug):
# this must be the Dropbox ROOT, i.e. the PARENT of the "repos" folder
# (e.g. /share/Dropbox), NOT /share/Dropbox/repos itself.
# GuidGroupsHelper.GetGuidGroupsForSearchFolders() internally does
# Path.Combine(searchPath, "repos") and expects repo-group GUID folders one
# level under that, then real repo folders one level under each of those:
#   <QNAP_REPOS_HOST_PATH>/repos/<group-guid>/<repo-folder>/...
# Pointing this directly at ".../repos" makes the app look for a
# nonexistent ".../repos/repos" and it finds 0 repos (crashes at startup).
# TODO(future refactor, not in scope now): GuidGroupsHelper hardcodes the
# "repos" segment and only reads searchFolders.First() — a legacy quirk the
# user wants to revisit later, not fixed as part of this QNAP TEST work.
QNAP_REPOS_HOST_PATH=/share/Dropbox
CONTAINER_REPOS_PATH=/data/repos

# Ports (test range, per the 12020-12029=test / 12030-12039=prod convention
# already used elsewhere in this project)
CONTENT_PROVIDER_API_PORT=12024
BLAZOR_PORT=12020

# QNAP's own address (hostname or Tailscale/LAN IP), used ONLY to bake the
# correct backend URL into the Blazor build (front_blazor/BlazorApp/wwwroot/appsettings.json
# -> ContentProviderApiUrl). Never hardcoded in the repo — set this in your
# real, gitignored .env.
QNAP_PUBLIC_HOST=change_me

# LEGACY / CONFIRMED UNUSED — declared in ConfigNames.cs and present in
# earlier drafts of this file, but grep found zero references to these in
# the actual C# source (2026-07-10). Kept here only for parity with the
# pre-existing example file; harmless if set, not required.
IdentityModule__DbFolderName=IdentityDatabase
IdentityModule__DbFileName=IdentityDatabase.db
PreparerModule__DbIdentityParentFolderSearchExpression=5(0,2)
PreparerModule__DropboxPath=/data/repos
PreparerModule__SettingsSearchExpr=0(0,1)
