@* @using Microsoft.AspNetCore.Authorization *@

@* @attribute [Authorize] *@



@inject AuthenticationStateProvider _authStateProvider
@* @inject Blazored.LocalStorage.ILocalStorageService _localStorage *@


<div class="rounded border p-3" style="width: 100%; max-width: 700px; margin: 0px;">
    <div>
        Repo::

        <ComboBox02
            @ref="_comboRef"
            Items="AllRepoModels"
            TextSelector="@GetItemName"
            ValueSelector="@GetItemId"
            SelectedItemChanged=@SelectedRepoNameChanged
        />
        @* @bind-SelectedItem=@SelectedRepoName/> *@
        @* OnValueChanged=@HandleValueChanged *@
    </div>
    <div>
        Loca::
        <input type="text" @bind=@inputLocaName />
    </div>

    @* toolbar *@
    <div class="menu-item">
        <button class="btn btn-sm repos-btn" type="button" @onclick=@OnBackArrowBtnClicked>←</button>
        <button class="btn btn-sm repos-btn" type="button" @onclick=@OnBackArrowBtnClicked>↶</button>
        <button class="btn btn-sm repos-btn" type="button" @onclick=@OnGoBtnClicked>GO</button>
        <button class="btn btn-sm repos-btn" type="button" @onclick=@OnBackArrowBtnClicked>→</button>
        <button class="btn btn-sm repos-btn" type="button" @onclick="LogoutAsync">Logout</button>
    </div>



    @if (_item != null)
    {
        <div class="menu-item">
            <div>Address: @ConvAddress(_item.Address)</div>
            <div>Type: @_item.Type</div>
            <div>Name: @_item.Name</div>
        </div>
        <div class="menu-item">
        <TextView @ref="textView" @bind-Item=@_item ReloadItemAsync=@ReloadItemByModel></TextView>
        <FolderView @ref="folderView" @bind-Item=@_item ReloadItemAsync=@ReloadItemByModel></FolderView>
    </div>
    }
    else
    {
        <div class="menu-item">
            Loading item...
        </div>
    }

</div>

