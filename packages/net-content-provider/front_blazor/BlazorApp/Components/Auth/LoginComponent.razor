@using BlazorApp.Models
@using BackendAdapters.Models
@using BlazorApp.Services

<div class="rounded border p-3" id="login-box" style="width: 100%; max-width: 400px; margin: 0px;">
    <h3 class="mb-3">Login</h3>
    <hr>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input class="form-control" @bind="email">
    </div>

    <div class="mb-3">
        <label class="form-label">Password</label>
        <input class="form-control" type="password" @bind="password">
    </div>

    <div class="row">
        <div class="col d-grid">
            <button class="btn btn-primary" @onclick="LoginAsync">Log in</button>
        </div>
        <div class="col d-grid">
            <button class="btn btn-outline-primary" @onclick="ShowRegister">Register</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <hr>
        <div class="alert alert-danger" role="alert">
            <strong>Connection Error</strong>
            <p class="mb-2">Nie udało się połączyć z API. Sprawdź, czy PublicWebApi działa i czy ContentProviderApiUrl wskazuje właściwy port.</p>
            
            <details class="mt-3">
                <summary class="cursor-pointer">Technical details / copy for debugging</summary>
                <div class="mt-2">
                    <pre class="bg-light p-2 border rounded" style="font-size: 0.85rem; white-space: pre-wrap; word-break: break-all;">@GetTechnicalDetails()</pre>
                    <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="CopyTechnicalDetails">Copy technical details</button>
                </div>
            </details>
        </div>
    }

    <div class="mt-3">
        <a href="javascript:void(0)" @onclick="ShowRegister">Don't have an account? Create one</a>
    </div>
</div>

@code {
    [Inject]
    private AuthenticationStateProvider provider { get; set; }

    [Inject]
    private IJSRuntime JS { get; set; }

    [Parameter]
    public EventCallback OnLoginSucceeded { get; set; }

    [Parameter]
    public EventCallback OnShowRegister { get; set; }

    public string email = "";
    public string password = "";
    public string error = "";

    private async Task LoginAsync()
    {
        var authStateProvider = (CustomAuthStateProvider) provider;
        var formResult = await authStateProvider.LoginAsync(email, password);
        if (formResult.Succeeded)
        {
            if (OnLoginSucceeded.HasDelegate)
            {
                await OnLoginSucceeded.InvokeAsync(null);
            }
        }
        else
        {
            error = formResult.Errors.Length > 0 ? formResult.Errors[0] : "Login failed";
        }
    }

    private async Task ShowRegister()
    {
        if (OnShowRegister.HasDelegate)
        {
            await OnShowRegister.InvokeAsync(null);
        }
    }

    private string GetTechnicalDetails()
    {
        var authStateProvider = (CustomAuthStateProvider) provider;
        return authStateProvider.LastDiagnostics.ToDetailedText();
    }

    private async Task CopyTechnicalDetails()
    {
        var details = GetTechnicalDetails();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", details);
    }
}
