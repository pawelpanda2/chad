@using BackendAdapters.Models

<select @bind="SelectedItem" class="dropdown-down">
    @foreach (var item in Items)
    {
        <option value="@ValueSelector(item)">@TextSelector(item)</option>
    }
</select>

@code {
    public ComboBox02()
    {
        Items = new List<ItemModel>();
        TextSelector = item => item.Name;
        ValueSelector = item => item.Id;
    }

    private List<ItemModel> _items;
    [Parameter]
    public List<ItemModel> Items
    {
        get
        {
            return _items;
        }
        set
        {
            _items = value;
            CheckSelectedItem();
        }
    }

    /// <summary>
    /// Function to extract display text from an item (default: item.Name)
    /// </summary>
    [Parameter]
    public Func<ItemModel, string> TextSelector { get; set; }

    /// <summary>
    /// Function to extract value from an item (default: item.Id)
    /// </summary>
    [Parameter]
    public Func<ItemModel, string> ValueSelector { get; set; }

    private void CheckSelectedItem()
    {
        if (SelectedItem != null
            && Items.Any(item => ValueSelector(item) == SelectedItem))
            return;

        if (Items == null || Items.Count < 1)
            return;

        ItemModel? first = Items.FirstOrDefault();
        if (first != null)
        {
            string? firstValue = ValueSelector(first);
            if (!string.IsNullOrEmpty(firstValue))
            {
                SelectedItem = firstValue;
            }
        }
    }

    [Parameter]
    public EventCallback<string> SelectedItemChanged { get; set; }

    // Wartość wybrana z ComboBoxa
    private string _selectedItem;
    public string SelectedItem
    {
        get => _selectedItem;
        set
        {
            string previous = _selectedItem;
            _selectedItem = value;
            if (previous != value)
            {
                SelectedItemChanged.InvokeAsync(SelectedItem);
            }
        }
    }

    public void SetSelectedItem(string newValue)
    {
        SelectedItem = newValue;
    }

    protected override void OnInitialized()
    {
        if (Items == null || Items.Count < 1)
            return;

        CheckSelectedItem();
    }
}