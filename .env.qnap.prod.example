# QNAP PROD — used with docker-compose.qnap.prod.yml
# Copy to .env on the QNAP prod deployment path. Never commit real values.

QNAP_CONTAINER_DATA_PATH=/share/ContainerData
MONGODB_PORT=27017
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me
MONGODB_URI=mongodb://change_me:change_me@localhost:27017/chad?authSource=admin
