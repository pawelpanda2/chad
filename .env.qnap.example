# QNAP — shared values for BOTH environments on the same QNAP host:
#   - bash-scripts/dashboard/04_qnap_test/
#   - bash-scripts/dashboard/05_qnap_prod/
#   - bash-scripts/dashboard/06_qnap_test_ssh/ and 07_qnap_prod_ssh/ (both
#     read this too — test/prod choice comes from which directory's wrapper
#     script you run, not a separate env file)
#
# Host, SSH credentials, repo location, and secrets are the same regardless
# of test/prod — only ports, container names, and the Compose project name
# differ, and those are hardcoded directly in each environment's own scripts
# (bash-scripts/dashboard/04_qnap_test/*.sh vs 05_qnap_prod/*.sh) — not in
# this file, and not in any separate config file.
#
# Copy to .env.qnap and fill in real values. Never commit .env.qnap (only
# this .example is meant to be committed).
#
# NOTE: this is a DIFFERENT deployment from packages/net-content-provider/
# 03_scripts/qnap/*.sh (standalone content-provider-api + Blazor GUI, no
# mongo, no dashboard — self-contained with its own .env.qnap-test, left
# untouched by this reorg).

# ============================================
# QNAP SSH (used by 06_qnap_test_ssh/*.sh and 07_qnap_prod_ssh/*.sh — never hardcode in scripts)
# ============================================
QNAP_SSH_HOST=100.117.139.83
QNAP_SSH_PORT=22
QNAP_SSH_USERNAME=change_me
QNAP_REPO_DIR=/share/qnap/03_files_programming/03_github/chad
QNAP_SSH_PASSWORD=

# ============================================
# QNAP public address (for building NEXT_PUBLIC_APP_URL etc.)
# ============================================
QNAP_PUBLIC_HOST=100.117.139.83

# ============================================
# MongoDB data path + app-level credentials (shared across test/prod —
# ports differ, hardcoded directly in each environment's own scripts)
#
# MUST resolve onto the real data volume, not a small `/share` tmpfs.
# On this QNAP, /share itself is a 16MB tmpfs — a plain directory under it
# (e.g. /share/ContainerData) silently inherits that, and MongoDB's
# WiredTiger journal will crash-loop with "No space left on device" once it
# fills. Point this at the mounted data volume instead, e.g.
# /share/CACHEDEV1_DATA/ContainerData (confirm the real volume on your QNAP
# with `df -h`; look for the large `/dev/mapper/cachedevN` mount, not
# `tmpfs`). 00_qnap_shared/03_restart.sh validates this path (free space +
# tmpfs detection) before starting Mongo — see
# documentation/ai-docs/deploy/qnap-data-path.md.
# ============================================
QNAP_CONTAINER_DATA_PATH=/share/CACHEDEV1_DATA/ContainerData
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me

# beeper-mongodb (Story 76, 2026-07-22) — deliberately SEPARATE credentials
# from chad-mongodb above (least privilege: a compromised Beeper container
# credential must not also grant access to cp_items). Standalone instance,
# no replica set — see docker-compose.qnap.shared.yml's own comment on the
# beeper-mongodb service.
BEEPER_MONGO_ROOT_USERNAME=change_me
BEEPER_MONGO_ROOT_PASSWORD=change_me

# ============================================
# Content Provider — two independent host paths holding real repo data
# (Story 68, corrected 2026-07-17 via a live SSH check of the real QNAP
# filesystem). Each must be the PARENT of that account's own "repos/"
# folder, not repos/ itself (see documentation/content-provider/next-tasks/
# qnap-test-deployment.md §6). /share/Dropbox is a symlink to
# /share/CACHEDEV1_DATA/Dropbox, which contains two separate account
# subfolders — there is no bare "/share/Dropbox/repos" and no "/shared/..."
# path on this QNAP (an earlier draft of this fix assumed "/shared/..."
# without verifying against the real filesystem — do not reintroduce it).
# Same real Dropbox data used by packages/net-content-provider's own
# standalone QNAP-TEST scripts (QNAP_REPOS_PATH_0/_1 in that app's own
# .env.qnap-test.example).
# ============================================
CP_REPOS_HOST_PATH=/share/Dropbox/pawelpanda2
CP_REPOS_HOST_PATH_2=/share/Dropbox/kamilgame042

# ============================================
# Database (Prisma) — SQLite
# ============================================
DATABASE_URL=file:/app/data/dev.db

# ============================================
# Console CLI — OpenAI key
# ============================================
OPENAI_API_KEY=change_me

# ============================================
# App metadata
# ============================================
NEXT_PUBLIC_APP_NAME="Personal Dashboard"

# ============================================
# GHCR (GitHub Container Registry) — used by
# bash-scripts/dashboard/09_registry_test/03_restart.sh and
# bash-scripts/dashboard/08_registry_prod/06_last_from_test.sh, both run
# over SSH on the QNAP host (Story 70). QNAP only ever PULLS — never builds
# or pushes — so this token must be read-only. The registry/owner/image
# name are non-secret and hardcoded in each environment's own
# 01_config.sh (same pattern as ports elsewhere) — only real secrets live
# here.
#
# GHCR_READ_TOKEN: a GitHub Personal Access Token (classic) with ONLY the
# `read:packages` scope. Create a SEPARATE token from the push one (do not
# reuse the Mac's write token here) at
# https://github.com/settings/tokens → "Generate new token (classic)" →
# tick `read:packages` only → generate → paste the value here (in
# .env.qnap, never in .env.qnap.example, never committed, never printed in
# any log — `docker login` is always invoked with `--password-stdin`).
# ============================================
GHCR_READ_USERNAME=change_me
GHCR_READ_TOKEN=change_me

# ============================================
# Story 75/76/78 — Google Sheets. Two independent concerns, two independent
# env surfaces (Story 78 — see packages/dba/src/google-sheets/config.ts's
# loadGoogleSheetsInfoConfig() vs loadGoogleSheetsConfig()):
#
#   1. WRITE SYNC (worker/outbox actually writes to Google) — the full
#      block below, GOOGLE_SHEETS_ENABLED + all other vars. Only ever wired
#      into docker-compose.qnap.prod.yml's `environment:` (never
#      .test.yml's) — also independently blocked outside real PROD by
#      packages/dba/src/google-sheets/production-guard.ts even if this
#      somehow got misconfigured. GOOGLE_SHEETS_ENABLED unset/false
#      disables write sync entirely; none of the other vars are required.
#   2. INFO PAGE (History -> Google Sheets link/info, read-only, no writes)
#      — only needs GOOGLE_SHEETS_SPREADSHEET_MAP + GOOGLE_SERVICE_ACCOUNT_EMAIL,
#      both non-secret (a spreadsheet ID/service-account email grant nothing
#      without the separately-secret private key). docker-compose.qnap.test.yml
#      wires ONLY these two — never GOOGLE_SHEETS_ENABLED, never
#      GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY — so TEST can show a user's
#      spreadsheet link without ever being able to write to it.
#
# See ai-docs/google-sheets/architecture.md and .env.local.example's own
# (more detailed) copy of this section for the full setup.
#
# GOOGLE_SHEETS_VIEWER_ACCOUNT_EMAIL/PASSWORD: optional, shown on the
# Dashboard's History -> Google Sheets page. Never entered here by the
# assistant on purpose — fill these in yourself if wanted.
# ============================================
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_MAP={"change_me_username":"change_me_spreadsheetId"}
GOOGLE_SHEETS_DAILY_TRACKER_SHEET_NAME=daily
GOOGLE_SHEETS_DATE_ENTRIES_SHEET_NAME=dates
GOOGLE_SERVICE_ACCOUNT_EMAIL=change_me@change_me.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=change_me
GOOGLE_SHEETS_VIEWER_ACCOUNT_EMAIL=
GOOGLE_SHEETS_VIEWER_ACCOUNT_PASSWORD=
