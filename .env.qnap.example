# QNAP — shared values for BOTH environments on the same QNAP host:
#   - bash-scripts/dashboard/04_qnap_test/
#   - bash-scripts/dashboard/05_qnap_prod/
#   - bash-scripts/dashboard/06_qnap_ssh/ (reads this too — test/prod choice
#     comes from which wrapper script you run, not a separate env file)
#
# Host, SSH credentials, repo location, and secrets are the same regardless
# of test/prod — only ports, container names, and the Compose project name
# differ, and those are hardcoded directly in each environment's own scripts
# (bash-scripts/dashboard/04_qnap_test/*.sh vs 05_qnap_prod/*.sh) — not in
# this file, and not in any separate config file.
#
# Copy to .env.qnap and fill in real values. Never commit .env.qnap (only
# this .example is meant to be committed).
#
# NOTE: this is a DIFFERENT deployment from packages/net-content-provider/
# 03_scripts/qnap/*.sh (standalone content-provider-api + Blazor GUI, no
# mongo, no dashboard — self-contained with its own .env.qnap-test, left
# untouched by this reorg).

# ============================================
# QNAP SSH (used by 06_qnap_ssh/*.sh — never hardcode in scripts)
# ============================================
QNAP_SSH_HOST=100.117.139.83
QNAP_SSH_PORT=22
QNAP_SSH_USERNAME=change_me
QNAP_REPO_DIR=/share/qnap/03_files_programming/03_github/chad
QNAP_SSH_PASSWORD=

# ============================================
# QNAP public address (for building NEXT_PUBLIC_APP_URL etc.)
# ============================================
QNAP_PUBLIC_HOST=100.117.139.83

# ============================================
# MongoDB data path + app-level credentials (shared across test/prod —
# ports differ, hardcoded directly in each environment's own scripts)
#
# MUST resolve onto the real data volume, not a small `/share` tmpfs.
# On this QNAP, /share itself is a 16MB tmpfs — a plain directory under it
# (e.g. /share/ContainerData) silently inherits that, and MongoDB's
# WiredTiger journal will crash-loop with "No space left on device" once it
# fills. Point this at the mounted data volume instead, e.g.
# /share/CACHEDEV1_DATA/ContainerData (confirm the real volume on your QNAP
# with `df -h`; look for the large `/dev/mapper/cachedevN` mount, not
# `tmpfs`). 00_qnap_shared/03_begin.sh validates this path (free space +
# tmpfs detection) before starting Mongo — see
# documentation/ai-docs/deploy/qnap-data-path.md.
# ============================================
QNAP_CONTAINER_DATA_PATH=/share/CACHEDEV1_DATA/ContainerData
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me

# ============================================
# Content Provider — host path holding real repo data. Must be the PARENT
# of a "repos/" folder, not repos/ itself (see documentation/content-provider/
# next-tasks/qnap-test-deployment.md §6). Same real Dropbox data used by
# packages/net-content-provider's own standalone QNAP-TEST scripts.
# ============================================
CP_REPOS_HOST_PATH=/share/Dropbox

# ============================================
# Database (Prisma) — SQLite
# ============================================
DATABASE_URL=file:/app/data/dev.db

# ============================================
# Console CLI — OpenAI key
# ============================================
OPENAI_API_KEY=change_me

# ============================================
# App metadata
# ============================================
NEXT_PUBLIC_APP_NAME="Personal Dashboard"
