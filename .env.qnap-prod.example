# QNAP PROD — full dashboard stack (mongo + content-provider-api + dashboard)
# under docker-compose, used by bash-scripts/dashboard/05_qnap_prod/*.sh,
# bash-scripts/dashboard/06_qnap_ssh/*_prod.sh, and docker-compose.qnap-prod.yml.
#
# PROD deployment requires separate explicit approval — creating these files
# does not deploy anything. See documentation/content-provider/next-tasks/
# qnap-test-deployment.md for the equivalent TEST docs.
#
# Copy to .env.qnap-prod and fill in real values. Never commit .env.qnap-prod
# (only this .example is meant to be committed).

# ============================================
# MongoDB (prod range: 27017, distinct from test 27018)
# ============================================
QNAP_CONTAINER_DATA_PATH=/share/ContainerData
MONGODB_PORT=27017
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me
MONGODB_URI=mongodb://change_me:change_me@localhost:27017/chad?authSource=admin

# ============================================
# Content Provider API (prod port range: 12030-12039)
# ============================================
# Host path holding real repo data — must be the PARENT of "repos/", not
# repos/ itself (see documentation/content-provider/next-tasks/
# qnap-test-deployment.md §6).
CP_REPOS_HOST_PATH=/share/Dropbox
CONTENT_PROVIDER_API_PORT=12034

# ============================================
# Dashboard frontend
# ============================================
FRONTEND_PORT=12035
DATABASE_URL=file:/app/data/dev.db

# ============================================
# QNAP address + SSH (used by 06_qnap_ssh/*_prod.sh — never hardcode in scripts)
# ============================================
QNAP_PUBLIC_HOST=100.117.139.83
QNAP_SSH_HOST=100.117.139.83
QNAP_SSH_PORT=22
QNAP_SSH_USERNAME=change_me
QNAP_REPO_DIR=change_me
QNAP_SSH_PASSWORD=

# ============================================
# Console CLI — OpenAI key
# ============================================
OPENAI_API_KEY=change_me

# ============================================
# App metadata
# ============================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_NAME=Personal Dashboard
NEXT_PUBLIC_APP_URL=http://100.117.139.83:12035
