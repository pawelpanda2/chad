# Local Mac dev — no Docker, no docker-compose. Used by pnpm/tmuxinator
# (bash-scripts/dashboard/02_local_mac/*) to run dashboard/console/dba
# directly on the host, and by the dashboard's own dev server.
#
# Copy to .env.local-mac and fill in real values. Never commit .env.local-mac
# (only this .example is meant to be committed).

# ============================================
# Ports (dev range)
# ============================================
FRONTEND_PORT=12080
BACKEND_PORT=12023
CONTENT_PROVIDER_API_PORT=12024

# ============================================
# Content Provider API — local Mac has no Docker network, so localhost
# ============================================
CONTENT_PROVIDER_API_URL=http://localhost:12024

# ============================================
# Database (Prisma) — SQLite, path relative to packages/dashboard
# ============================================
DATABASE_URL=file:./dev.db

# ============================================
# Console CLI — OpenAI key (get your own at platform.openai.com)
# ============================================
OPENAI_API_KEY=change_me

# ============================================
# App metadata
# ============================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_NAME=Personal Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:12080
