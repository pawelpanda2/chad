{
  "name": "chad",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dba": "pnpm --filter dba dev",
    "dba:build": "pnpm --filter dba build",
    "dashboard": "pnpm --filter dashboard dev",
    "console": "pnpm --filter console dev",
    "beeper:ws": "pnpm --filter beeper-ws dev",
    "beeper:sync": "pnpm --filter beeper-sync sync",
    "beeper:sync:force": "pnpm --filter beeper-sync sync:force",
    "beeper:oplog": "pnpm --filter beeper-oplog dev",
    "mongo:up": "docker compose -f docker-compose.local.yml up -d mongodb",
    "mongo:backup": "./bash-scripts/mongo/backup.sh",
    "mongo:restore": "./bash-scripts/mongo/restore.sh",
    "mongo:migrate-contacts": "node ./bash-scripts/mongo/migrate-contacts-to-chad.mjs",
    "mongo:migrate-contacts:apply": "node ./bash-scripts/mongo/migrate-contacts-to-chad.mjs --apply",
    "dev": "./bash-scripts/dev.sh"
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}
