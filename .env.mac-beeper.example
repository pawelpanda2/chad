# Mac-side env for beeper-ws / beeper-sync (packages/beeper-ws,
# packages/beeper-sync — see documentation/beeper/architecture.md).
#
# These two processes run on the Mac (next to Beeper Desktop). As of
# Story 59, their target MongoDB is the same local `chad` MongoDB the
# dashboard uses (docker-compose.local.yml's `mongodb` service, database
# `beeper` — see backlog/stories/59/02_plan.md Phase 0). QNAP is not yet
# wired up for beeper-ws/beeper-sync; that's Story 59 Phase 2/3.
#
# Copy this to `.env.mac-beeper` (gitignored, never commit it) and fill in
# the REAL values there (Beeper API key, Mongo credentials matching your
# local .env.local). Never put real secrets in this committed .example file.

# Local chad MongoDB, reached from the Mac host (not from inside a
# container) — hence `localhost`, not `mongodb` (that compose-internal DNS
# name only resolves from other containers on the same compose network) and
# not `host.docker.internal` (that's for containers reaching the host, the
# reverse direction). Server URI only — no database segment. Story 73: each
# CHAD user gets their own `beeper_<repoGuid>` database (see
# BEEPER_OWNER_REPO_GUID below); the old single shared `beeper` database
# from the Phase 0 decision in backlog/stories/59/02_plan.md is retired.
# Credentials must match MONGO_ROOT_USERNAME/MONGO_ROOT_PASSWORD in the root
# .env.local.
MONGODB_URI=mongodb://change_me:change_me@localhost:27017?authSource=admin

# Story 73: required. This process has no Dashboard session to resolve a
# repoGuid from, so the owner of this Mac's Beeper data must be configured
# explicitly — beeper-ws/beeper-sync refuse to start without a full GUID
# here, and will only ever read/write `beeper_<repoGuid>`, never any other
# user's database. See documentation/beeper/architecture.md.
BEEPER_OWNER_REPO_GUID=21d11bdc-f1f4-44d1-b61a-3fa6b039c641

# Future QNAP form (Story 59 Phase 2/3, not active yet): once beeper-ws/
# beeper-sync move to targeting QNAP's MongoDB over Tailscale, this becomes
# something like:
#   mongodb://<user>:<pass>@<qnap-tailscale-host>:27017?authSource=admin&directConnection=true
# directConnection=true will be required once MongoDB on QNAP runs as a
# replica set (needed for beeper-oplog's change streams) — see
# documentation/ai-docs/2026-07-10_mongodb-replica-set-migration-plan.md.
# Not needed for the current local-only setup. BEEPER_OWNER_REPO_GUID for a
# future kamil_s device would be 8b603669-f8e6-4224-bd78-a474998995fa.

# Beeper Desktop local endpoints (same-machine assumption — see
# documentation/ai-docs/2026-07-10_decision-beeper-mac-qnap-architecture.md)
BEEPER_WS_URL=ws://localhost:23373/v1/ws
BEEPER_REST_URL=http://localhost:23373
BEEPER_API_KEY=change_me

# Local Beeper SQLite path used by beeper-sync — must come from env, never
# hardcoded in scripts (source repo had this hardcoded, to be fixed on migration)
BEEPER_SQLITE_PATH=/Users/change_me/Library/Application Support/BeeperTexts/index.db

# Optional: only set this if account.db lives outside BEEPER_SQLITE_PATH's
# directory. By default beeper-sync/enrich-from-sqlite.mjs derives it as
# "account.db" next to BEEPER_SQLITE_PATH (same BeeperTexts folder).
# BEEPER_SQLITE_ACCOUNT_PATH=/Users/change_me/Library/Application Support/BeeperTexts/account.db
