# Mac-side env for beeper-ws / beeper-sync (NOT yet migrated into this repo —
# this file documents the intended shape ahead of that migration).
#
# These two processes run on the Mac (next to Beeper Desktop) and connect to
# MongoDB on QNAP over Tailscale — never localhost, never a hardcoded IP.
#
# Copy this to `.env.mac-beeper` (gitignored, never commit it) and fill in
# the REAL Tailscale host there. Never put the real host in a committed
# .example file or in documentation.

QNAP_TAILSCALE_HOST=100.x.x.x
MONGODB_PORT=27017
MONGO_APP_USERNAME=change_me
MONGO_APP_PASSWORD=change_me
# directConnection=true is required once MongoDB on QNAP runs as a replica
# set (needed for beeper-oplog's change streams): the replica set member is
# registered internally as "mongodb:27017" (the Docker Compose service
# name), which this Mac-side client cannot resolve. directConnection=true
# tells the driver to talk only to the given host:port and skip full
# replica-set topology discovery. See
# documentation/ai-docs/2026-07-10_mongodb-replica-set-migration-plan.md.
# Not needed yet while MongoDB is still standalone.
MONGODB_URI=mongodb://${MONGO_APP_USERNAME}:${MONGO_APP_PASSWORD}@${QNAP_TAILSCALE_HOST}:${MONGODB_PORT}/chad?authSource=admin&directConnection=true

# Beeper Desktop local endpoints (same-machine assumption — see
# documentation/ai-docs/2026-07-10_decision-beeper-mac-qnap-architecture.md)
BEEPER_WS_URL=ws://localhost:23373/v1/ws
BEEPER_REST_URL=http://localhost:23373
BEEPER_API_KEY=change_me

# Local Beeper SQLite path used by beeper-sync — must come from env, never
# hardcoded in scripts (source repo had this hardcoded, to be fixed on migration)
BEEPER_SQLITE_PATH=/Users/change_me/Library/Application Support/BeeperTexts/index.db
