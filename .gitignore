__pycache__/
*.pyc
*.pyo
.Python
.venv/
venv/
env/
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ============================================
# Env files (never commit real secrets)
# Broad by design: matches .env, .env.local, and every numbered/legacy
# variant carried over from the source repos (.env.02_local_mac,
# .env.05_docker_qnap_test, .env.mac-beeper, etc.) — only *.example files
# are meant to be committed.
# ============================================
.env
.env.*
!.env.example
!.env.*.example

# ============================================
# Secrets / keys / credentials — broad by design, "na zapas"
# ============================================
*.pem
*.key
*.p12
*.pfx
*.ppk
id_rsa*
id_ed25519*
*.db
*token*.json
*credential*.json
*secret*.json
.npmrc
.netrc
.aws/
.gcp/
gcloud-service-key.json
*service-account*.json

# ============================================
# Archives — "na zapas": nothing zipped/tarred should ever be committed
# by accident (build caches, OS junk, forgotten exports all tend to hide
# inside these). If a real asset genuinely needs to be an archive, force it:
# git add -f path/to/file.zip
# ============================================
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.7z
*.rar
__MACOSX/

# ============================================
# Database dumps / local data
# ============================================
*.dump
*.sqlite
*.sqlite3
mongodb-data/
bash-scripts/mongo/backups/*
!bash-scripts/mongo/backups/.gitkeep

# prisma generated client / local sqlite (dashboard)
node_modules/.prisma
/lib/generated/prisma

# ============================================
# Logs
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# Coverage / test artifacts
# ============================================
coverage/
.nyc_output/
TestResults/
*.lcov

# ============================================
# OS junk
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================
# Editor / IDE
# ============================================
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.settings/

# ============================================
# Infra state (defensive — none expected here yet, but never commit if it shows up)
# ============================================
*.tfstate
*.tfstate.backup
.terraform/

# runtime state for dashboard start/stop scripts (ownership markers etc.)
.tmp/

# writable Docker CLI config dir for QNAP scripts (Container Station sets
# HOME to a directory the SSH user can't write to — see
# bash-scripts/dashboard/{04_qnap_test,05_qnap_prod}/01_config.sh)
.docker-qnap/

# generated per-environment module config files (e.g. content-provider's
# appsettings.json), written by each environment's 01_config.sh before
# `docker compose up` / `docker run` — never the source of truth, always
# regenerated from the text embedded in that environment's 01_config.sh
.runtime/

# Per-host release-tag records for CHAD's own Docker images (chad-dashboard,
# chad-content-provider-api) — written by each environment's 02_build.sh,
# read by 03_begin.sh. State, not source of truth: never committed. See
# documentation/ai-docs/deploy/image-tagging-standard.md.
.image-tag.*.env
